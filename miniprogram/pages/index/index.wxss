.index-page {
  padding-top: 0;
}

.hero {
  min-height: 270rpx;
  margin: 0 -24rpx;
  padding: 44rpx 24rpx 34rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  background: linear-gradient(135deg, #0f3f8f 0%, #1b6bd8 58%, #d52e42 100%);
  color: #ffffff;
}

.hero-kicker {
  font-size: 24rpx;
  opacity: 0.9;
}

.hero-title {
  margin-top: 12rpx;
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1.15;
}

.hero-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  opacity: 0.86;
}

.refresh-btn {
  flex: 0 0 auto;
  min-width: 132rpx;
  height: 68rpx;
  padding: 0 22rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  font-size: 26rpx;
  line-height: 66rpx;
}

.refresh-btn::after {
  border: 0;
}

.latest-meta {
  margin-top: 8rpx;
}

.latest-skeleton {
  margin-top: 34rpx;
  width: 100%;
}

.latest-skeleton.short {
  width: 68%;
}

.latest-balls {
  margin-top: 34rpx;
}

.latest-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 30rpx;
}

.stat {
  padding: 20rpx;
  border-radius: 8rpx;
  background: #f7f9fd;
}

.stat-label {
  color: #68738d;
  font-size: 22rpx;
}

.stat-value {
  margin-top: 8rpx;
  color: #17233f;
  font-size: 30rpx;
  font-weight: 700;
}

.detail-btn {
  margin-top: 30rpx;
}

.quick-head {
  margin-bottom: 24rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.quick-card {
  min-height: 190rpx;
  padding: 22rpx;
  border: 1rpx solid #e4e9f3;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(17, 36, 72, 0.06);
}

.quick-title {
  color: #17233f;
  font-size: 28rpx;
  font-weight: 700;
}

.quick-date {
  margin-top: 8rpx;
  color: #0f3f8f;
  font-size: 24rpx;
}

.quick-note {
  margin-top: 22rpx;
  color: #68738d;
  font-size: 23rpx;
  line-height: 1.5;
}

.mini-balls {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 20rpx;
}

.mini-ball {
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border-radius: 17rpx;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 34rpx;
  text-align: center;
}

.mini-ball.red {
  background: #dc2f45;
}

.mini-ball.blue {
  background: #1664d9;
}

.adjacent-row {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 18rpx;
}

.adjacent-link {
  min-height: 42rpx;
  color: #0f3f8f;
  font-size: 23rpx;
  line-height: 42rpx;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}
