<view class="page index-page">
  <view class="hero">
    <view>
      <view class="hero-kicker">开奖结果查询</view>
      <view class="hero-title">彩票查询</view>
    </view>
    <button class="refresh-btn" bindtap="handleRefresh" loading="{{refreshing}}">刷新</button>
  </view>

  <view class="type-tabs">
    <view
      wx:for="{{lotteryTypes}}"
      wx:key="key"
      class="type-tab {{currentType === item.key ? 'active' : ''}}"
      bindtap="switchType"
      data-type="{{item.key}}"
    >{{item.name}}</view>
  </view>

  <view wx:if="{{error}}" class="section error">{{error}}</view>

  <view class="section panel latest-panel">
    <view class="row between">
      <view>
        <view class="panel-title">最近一期</view>
        <view class="muted latest-meta" wx:if="{{latest.issue}}">第 {{latest.issue}} 期 · {{latest.drawDate}}</view>
      </view>
      <view class="tag">{{syncLabel}}</view>
    </view>

    <block wx:if="{{loading}}">
      <view class="skeleton latest-skeleton"></view>
      <view class="skeleton latest-skeleton short"></view>
    </block>

    <block wx:elif="{{latest.issue}}">
      <view class="balls latest-balls">
        <view wx:for="{{latest.frontNumbers}}" wx:key="*this" class="ball ball-red">{{item}}</view>
        <view wx:for="{{latest.backNumbers}}" wx:key="*this" class="ball ball-blue">{{item}}</view>
      </view>
      <view class="latest-stats">
        <view class="stat">
          <view class="stat-label">销售额</view>
          <view class="stat-value">{{latest.salesText}}</view>
        </view>
        <view class="stat">
          <view class="stat-label">奖池</view>
          <view class="stat-value">{{latest.poolText}}</view>
        </view>
      </view>
      <button class="btn detail-btn" bindtap="goLatestDetail">查看详情</button>
    </block>

    <view wx:else class="empty">暂无开奖记录，请先配置云环境并同步数据。</view>
  </view>

  <view class="section quick-section">
    <view class="row between quick-head">
      <view class="panel-title">同日查询</view>
      <view class="muted">{{today}}</view>
    </view>

    <view class="quick-grid">
      <view wx:for="{{quickItems}}" wx:key="type" class="quick-card" bindtap="openQuick" data-type="{{item.type}}">
        <view class="quick-title">{{item.title}}</view>
        <view class="quick-date">{{item.targetDate}}</view>
        <block wx:if="{{item.result.issue}}">
          <view class="mini-balls">
            <text wx:for="{{item.result.frontNumbers}}" wx:key="*this" class="mini-ball red">{{item}}</text>
            <text wx:for="{{item.result.backNumbers}}" wx:key="*this" class="mini-ball blue">{{item}}</text>
          </view>
          <view wx:if="{{item.corrected}}" class="quick-note">已按自然日期修正</view>
        </block>
        <block wx:elif="{{item.message}}">
          <view class="quick-note">{{item.message}}</view>
          <view wx:if="{{item.corrected}}" class="quick-note">已按自然日期修正</view>
          <view wx:if="{{item.previous || item.next}}" class="adjacent-row">
            <view wx:if="{{item.previous}}" class="adjacent-link" catchtap="openAdjacent" data-issue="{{item.previous.issue}}">前一期 {{item.previous.issue}}</view>
            <view wx:if="{{item.next}}" class="adjacent-link" catchtap="openAdjacent" data-issue="{{item.next.issue}}">后一期 {{item.next.issue}}</view>
          </view>
        </block>
        <view wx:else class="quick-note">查询中</view>
      </view>
    </view>
  </view>

  <view class="section action-row">
    <button class="btn" bindtap="goHistory">历史查询</button>
    <button class="btn btn-secondary" bindtap="goAbout">数据说明</button>
  </view>
</view>
